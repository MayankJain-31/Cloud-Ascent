# ---- Cloud Ascent backend configuration ----
# Copy this file to .env and fill in real values. NEVER commit .env.

# Node environment: development | production
NODE_ENV=development

# Port the API listens on
PORT=8080

# Secret used to sign session JWTs. MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server REFUSES to start in production if this is missing or too short.
JWT_SECRET=

# Comma-separated list of origins allowed to call the API (CORS).
# For local dev with the static frontend on :5173 or file server, list them here.
# In production set this to your GitHub Pages / site origin, e.g. https://you.github.io
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Path to the SQLite database file (created automatically).
DB_PATH=./data/cloud-ascent.db

# Set to 1 to serve the built frontend from the backend at "/" (single-service deploy).
SERVE_FRONTEND=1
